# Copia este archivo como ".env" y rellena los valores (nunca subas .env a Git).

# --- Obligatorio: MCP + scripts contra WordPress ---
# URL pública del sitio, sin barra final
WP_BASE_URL=https://tu-dominio.com

# Usuario de WordPress (con permiso para editar entradas/páginas si vas a limpiar)
WP_USERNAME=tu_usuario

# Contraseña de aplicación: WP Admin → Usuarios → Perfil → Contraseñas de aplicación
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# --- Muy recomendado para scripts de limpieza ---
# Host de TU sitio sin https:// (ej. tu-dominio.com o www.tu-dominio.com según uses en enlaces)
# Así los scripts no marcan como "spam" tus propias URLs.
WP_SITE_HOST=tu-dominio.com

# --- Opcional: diagnóstico y páginas ---
# Si la API de ajustes no devuelve la portada estática, pon aquí el ID de la página de inicio
# WP_FRONT_PAGE_ID=123

# Sonda genérica para pruebas manuales (evita falsos positivos en sitios que hablen de casinos legítimamente)
# SPAM_PROBE=palabra_o_marca_del_spam

# Subcadenas separadas por comas para detect-elementor-rest-divergence.mjs
# SPAM_PROBE_SUBSTRINGS=casino,left:-9999

# Fragmento HTML que exista igual en la home y en el contenido API (solo probe-home-vs-api.mjs)
# COMPARE_HTML_MARKER=
